{
  "name": "stage5-api",
  "version": "1.0.0",
  "description": "Stage 5 API service for payments, credits, and shared features",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "start": "node dist/index.js",
    "build": "tsc",
    "audit:credits": "node scripts/audit-credit-economics.mjs",
    "migrations:status": "node scripts/d1-migration-status.mjs",
    "migrations:verify": "node scripts/d1-migration-status.mjs --fail-if-pending",
    "migrations:apply": "npx wrangler d1 migrations apply stage5_db --remote && npm run migrations:status",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "npm run build && node --import ../translator/node_modules/tsx/dist/loader.mjs --test tests/*.test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/s3-request-presigner": "^3.940.0",
    "@types/uuid": "^10.0.0",
    "hono": "^4.0.0",
    "js-tiktoken": "^1.0.21",
    "openai": "^4.33.1",
    "stripe": "^20.0.0",
    "uuid": "^13.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "better-sqlite3": "^9.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.19.1"
  },
  "engines": {
    "node": ">=18"
  }
}
